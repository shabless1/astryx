# ─── ASTRYX ENVIRONMENT VARIABLES ───────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ── App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── NextAuth (REQUIRED)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth (optional)
# console.cloud.google.com → Credentials → OAuth 2.0
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── XRP Payments
# Your XRP wallet address (users send payments here)
NEXT_PUBLIC_XRP_ADDRESS=rYourXRPWalletAddressHere
# mainnet for real money, testnet for dev
XRP_NETWORK=testnet

# ── Suno Music Library (REQUIRED to enable real-world instrument tracks)
#
# Set this to the base URL where your 120 Suno MP3s are hosted.
# URL shape: {NEXT_PUBLIC_AUDIO_BASE_URL}/{planet}/{state}/{filename}.mp3
# e.g. https://pub-xxx.r2.dev/audio/mars/exc/MARS_EXC_01.mp3
#
# OPTIONS:
#   Cloudflare R2 (recommended — free 10GB, fast CDN, CORS configurable):
#     NEXT_PUBLIC_AUDIO_BASE_URL=https://pub-YOURID.r2.dev/audio
#   Vercel Blob:
#     NEXT_PUBLIC_AUDIO_BASE_URL=https://xxxxx.public.blob.vercel-storage.com/audio
#   Local dev (files in public/audio/library/):
#     NEXT_PUBLIC_AUDIO_BASE_URL=/audio/library
#
# ⚠ Google Drive CANNOT serve audio cross-origin reliably.
#   Upload your tracks to R2 or Vercel Blob for production.
#   See SUNO_LIBRARY/HOSTING_GUIDE.md for step-by-step R2 setup.
#
# If unset, the Suno layer is silently disabled and Tone.js synthesis plays alone.
NEXT_PUBLIC_AUDIO_BASE_URL=

# Feature flags
NEXT_PUBLIC_SHOP_LIVE=false
NEXT_PUBLIC_SACRED_TONES_SHOP_LIVE=false

# ── Shopify fork-buyer entitlement (Directive v4.0 Fix 2)
# Webhook signing secret — Shopify Admin > Settings > Notifications > Webhooks
SHOPIFY_WEBHOOK_SECRET=
# Comma-separated SKUs of the Sacred Tones fork products (fallback: title contains "tuning fork")
SHOPIFY_FORK_SKUS=
# Comma-separated emails granted beta access manually (no purchase needed)
BETA_ALLOWLIST=
# The Sacred Tones fork set product page (fork-access screen CTA)
NEXT_PUBLIC_FORK_SHOP_URL=https://sacredtea.net

# ── Astryx Intelligence (Directive L — the full-canon brain)
# The chat (/api/astryx) uses a swappable model adapter. Default = Gemini (free
# tier). Keys are server-only. If unset, Astryx degrades to the local sovereign
# brain (retrieval-only) — she never goes dark.
#
# Provider select: gemini (default) | openai | selfhost
ASTRYX_MODEL_PROVIDER=gemini
# Gemini (default) — reuses the existing key.
GEMINI_API_KEY=your-gemini-api-key
# OpenAI (drop-in A/B — set provider=openai). Optional.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Self-host (Phase 2 — point at an OpenAI-compatible Ollama/vLLM endpoint).
# SELFHOST_LLM_URL=http://localhost:11434
# SELFHOST_LLM_MODEL=llama3.1
# Tier-3 curated web (Phase 2 — OFF until you flip it).
ASTRYX_WEB_ENABLED=false

# ── Astryx Voice (Directive v4.0 Fix 6 — TTS on chat + daily headline)
# Reuses OPENAI_API_KEY. Model + fixed brand voice (no picker — one voice).
OPENAI_TTS_MODEL=gpt-4o-mini-tts
ASTRYX_TTS_VOICE=sage

# ── Database (Directive v4.0 Fix 1 — REQUIRED: Supabase Postgres via Prisma)
# Pooled connection (Supavisor transaction mode, port 6543) — runtime queries
DATABASE_URL=postgresql://USER.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Session connection (port 5432) — prisma migrate deploy only
DIRECT_URL=postgresql://USER.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres
